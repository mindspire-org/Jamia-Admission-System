# ===========================================
# JAMIA ADMISSION SYSTEM - ENVIRONMENT CONFIG
# ===========================================
# Copy this file to .env and modify as needed
# For LAN deployment, see instructions below

# --- SERVER CONFIGURATION ---
PORT=5000

# --- MONGODB ---
# Standalone/Server: Use localhost MongoDB
MONGO_URI=mongodb://localhost:27017/madrasa_admission

# --- SECURITY ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# --- ENVIRONMENT ---
NODE_ENV=development

# --- AUTO SEED (first run) ---
AUTO_SEED_ADMIN=true
AUTO_SEED_GRADES=true

# --- API URL (IMPORTANT FOR LAN DEPLOYMENT) ---
# Leave empty for standalone/server mode (uses localhost)
# For LAN CLIENT: Set to server's LAN IP address
# VITE_API_URL=http://192.168.1.100:5000/api

# ===========================================
# LAN DEPLOYMENT INSTRUCTIONS
# ===========================================
#
# STEP 1: SERVER MACHINE SETUP
# ----------------------------
# 1. Install MongoDB and edit mongod.cfg:
#    bindIp: 0.0.0.0  (allows LAN connections)
#
# 2. Add Windows Firewall inbound rule:
#    - Port: 5000 (backend API)
#    - Port: 27017 (MongoDB - if clients need direct access)
#
# 3. Install the app on server
# 4. Edit .env in app's userData folder:
#    - Windows: %APPDATA%\Jamia Admission System\.env
#    - MONGO_URI=mongodb://localhost:27017/madrasa_admission
#    - Leave VITE_API_URL empty or commented out
#
# STEP 2: CLIENT MACHINE SETUP
# ----------------------------
# 1. Install the app on client
# 2. Edit .env in app's userData folder:
#    - VITE_API_URL=http://SERVER_LAN_IP:5000/api
#    - Example: VITE_API_URL=http://192.168.1.100:5000/api
#    - MONGO_URI=mongodb://SERVER_LAN_IP:27017/madrasa_admission
#    - Example: MONGO_URI=mongodb://192.168.1.100:27017/madrasa_admission
#
# 3. The client will NOT start its own backend
#    It will connect to the server's API
#
# FINDING YOUR LAN IP:
# - Windows: Open CMD, run: ipconfig
# - Look for "IPv4 Address" under your network adapter
# - Usually starts with 192.168.x.x or 10.x.x.x
#
# ===========================================
